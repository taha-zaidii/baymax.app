# ── API Keys ──────────────────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get from: https://serper.dev  (free 100 searches/month)
SERPER_API_KEY=your_serper_api_key_here

# ── Groq Model Selection ──────────────────────────────────────────────────────
# Primary model (recommended for quality): llama-3.3-70b-versatile
# Fast model (recommended for speed): mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=mixtral-8x7b-32768

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Backend Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── App Settings ──────────────────────────────────────────────────────────────
APP_TITLE=Baymax AI
ENVIRONMENT=development
